{
  "name": "@donniean/node-app",
  "version": "0.0.0",
  "homepage": "https://github.com/donniean/node-app#readme",
  "bugs": {
    "url": "https://github.com/donniean/node-app/issues"
  },
  "license": "MIT",
  "author": "Donnie An",
  "repository": {
    "type": "git",
    "url": "https://github.com/donniean/node-app.git"
  },
  "bin": {
    "configs-md": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "pnpm run build --watch",
    "changeset:add": "changeset add",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "clean": "rimraf dist/",
    "dev": "tsx src/cli",
    "docs": "tsx src/scripts",
    "format:oxfmt": "oxfmt",
    "format:oxfmt:check": "oxfmt --check",
    "link": "pnpm run build && pnpm link",
    "lint": "concurrently --group --timings \"pnpm:format:*:check\" \"pnpm:lint:*(!:fix)\" \"pnpm:typecheck\"",
    "lint:autocorrect": "autocorrect --lint",
    "lint:autocorrect:fix": "autocorrect --fix",
    "lint:fix": "concurrently --max-processes=1 --group --timings \"pnpm:lint:*:fix\" \"pnpm:format:*(!:check)\"",
    "lint:knip": "knip",
    "lint:knip:fix": "knip --fix",
    "lint:markdown": "markdownlint --dot .",
    "lint:markdown:fix": "pnpm run lint:markdown --fix",
    "lint:oxlint": "oxlint",
    "lint:oxlint:fix": "oxlint --fix",
    "lint:spellcheck": "cspell --no-progress --dot --gitignore .",
    "ncu": "ncu --deep --format cooldown",
    "ncu:upgrade": "pnpm run ncu --upgrade",
    "postdocs": "oxfmt configs.md",
    "prebuild": "pnpm run clean",
    "prepare": "husky",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --pass-with-no-tests",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:unit:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "15.0.0",
    "fs-extra": "11.3.6",
    "json2md": "2.0.3",
    "remark": "15.0.1",
    "remark-toc": "9.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@commitlint/types": "21.2.0",
    "@types/fs-extra": "11.0.4",
    "@types/json2md": "1.5.4",
    "@types/node": "24.13.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "4.1.10",
    "autocorrect-node": "2.14.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "husky": "9.1.7",
    "knip": "6.27.0",
    "lint-staged": "17.1.0",
    "markdownlint-cli": "0.49.1",
    "npm-check-updates": "22.2.9",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "pnpm@11.15.0"
}
