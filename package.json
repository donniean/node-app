{
  "name": "@donniean/node-app",
  "version": "0.0.0",
  "homepage": "https://github.com/donniean/node-app#readme",
  "bugs": {
    "url": "https://github.com/donniean/node-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/donniean/node-app.git"
  },
  "license": "MIT",
  "author": "Donnie An",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "configs-md": "./bin/cli.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "prebuild": "pnpm run clean",
    "build": "tsup",
    "build:watch": "pnpm run build --watch",
    "changeset:add": "changeset add",
    "changeset:publish": "changeset publish",
    "changeset:version": "changeset version",
    "clean": "rimraf dist/",
    "dev": "tsx src/cli",
    "docs": "tsx src/scripts",
    "postdocs": "prettier --write configs.md",
    "format:package-json": "sort-package-json \"**/package.json\" --ignore \"**/node_modules/**/package.json\" --ignore \"**/dist/**/package.json\"",
    "format:package-json:check": "pnpm run format:package-json --check",
    "format:prettier": "prettier --write --ignore-unknown .",
    "format:prettier:check": "prettier --check --ignore-unknown .",
    "preinstall": "npx only-allow@latest pnpm",
    "link": "pnpm run build && pnpm link",
    "lint": "concurrently --group --timings \"pnpm:lint:*(!:fix|^lint:knip$)\" \"pnpm:format:*:check\" \"pnpm:typecheck\"",
    "lint:autocorrect": "autocorrect --lint",
    "lint:autocorrect:fix": "autocorrect --fix",
    "lint:eslint": "eslint",
    "lint:eslint:fix": "eslint --fix",
    "lint:fix": "concurrently --max-processes=1 --group --timings \"pnpm:lint:*:fix(!^lint:knip:fix$)\" \"pnpm:format:*(!:check)\"",
    "lint:knip": "knip",
    "lint:knip:fix": "knip --fix",
    "lint:markdown": "markdownlint --dot \"**/*.md\"",
    "lint:markdown:fix": "pnpm run lint:markdown --fix",
    "lint:spellcheck": "cspell lint --no-progress --no-must-find-files --dot --gitignore .",
    "ncu": "ncu --deep --format cooldown",
    "ncu:upgrade": "pnpm run ncu --upgrade",
    "prepare": "husky",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --pass-with-no-tests",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:unit:watch": "vitest watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "15.0.0",
    "fs-extra": "11.3.5",
    "json2md": "2.0.3",
    "prettier": "3.8.4",
    "remark": "15.0.1",
    "remark-toc": "9.0.0",
    "type-fest": "5.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/types": "21.0.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@types/fs-extra": "11.0.4",
    "@types/json2md": "1.5.4",
    "@types/node": "24.13.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.20",
    "@vitest/ui": "4.1.8",
    "autocorrect-node": "2.14.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "65.0.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "knip": "6.16.1",
    "lint-staged": "17.0.7",
    "markdownlint-cli": "0.48.0",
    "npm-check-updates": "22.2.3",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "sort-package-json": "4.0.0",
    "tsup": "8.5.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  }
}
